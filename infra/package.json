{
  "name": "chme-infra",
  "version": "1.0.0",
  "description": "CHME Infrastructure as Code",
  "bin": {
    "chme": "bin/chme.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy:dev": "cdk deploy --all --context stage=dev",
    "deploy:prod": "cdk deploy --all --context stage=prod",
    "diff:dev": "cdk diff --context stage=dev",
    "diff:prod": "cdk diff --context stage=prod",
    "synth:dev": "cdk synth --context stage=dev",
    "synth:prod": "cdk synth --context stage=prod",
    "destroy:dev": "cdk destroy --all --context stage=dev",
    "destroy:prod": "cdk destroy --all --context stage=prod"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "aws-cdk": "^2.117.0",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.3.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.117.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  }
}
